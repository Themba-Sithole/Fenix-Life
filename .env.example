# =============================================================================
# Fenix Life — Environment Variables
# Copy this file to `.env` in the project root and fill in your values.
# Never commit `.env` to git.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Neon — free tier)
# Sign up: https://neon.tech
# Dashboard → Project → Connection string → copy "Pooled connection"
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"

# Comma-separated URLs allowed to call the API (add your Vercel URL after deploy)
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"

# -----------------------------------------------------------------------------
# REDIS (Upstash — free tier, optional for now)
# Sign up: https://upstash.com → Create Redis database
# -----------------------------------------------------------------------------
# REDIS_URL="rediss://default:PASSWORD@HOST:6379"

# -----------------------------------------------------------------------------
# FRONTEND (Vite — used at build time on Vercel)
# Local: http://localhost:3001/v1
# Production: https://YOUR-API.onrender.com/v1
# -----------------------------------------------------------------------------
VITE_API_URL="http://localhost:3001/v1"
