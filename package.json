{
  "name": "fenix-life",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:client": "npm run dev --workspace=@fenix/client",
    "dev:api": "npm run dev --workspace=@fenix/api",
    "dev:admin": "npm run dev --workspace=@fenix/admin",
    "build:client": "npm run build --workspace=@fenix/client",
    "build:api": "npm run build --workspace=@fenix/api",
    "db:push": "npm run db:push --workspace=@fenix/api",
    "db:studio": "npm run db:studio --workspace=@fenix/api",
    "admin:seed": "npm run admin:seed --workspace=@fenix/api",
    "build:admin": "npm run build --workspace=@fenix/admin",
    "test:unit": "npm test --workspace=@fenix/domain && npm test --workspace=@fenix/simulation-engine",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.31.0",
    "turbo": "^2.5.4",
    "typescript-eslint": "^8.33.0"
  }
}
